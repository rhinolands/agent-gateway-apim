# Option A — env vars. Copy to .env (gitignored), fill in, then: set -a; source .env; set +a
# Terraform reads TF_VAR_<name> automatically. (Option B = infra/terraform.tfvars.)
export TF_VAR_resource_group_name=rg-agent-gateway
export TF_VAR_location=westeurope
export TF_VAR_name_prefix=agentgw
export TF_VAR_publisher_name="Your Name"
export TF_VAR_publisher_email=publisher@example.org
export TF_VAR_tenant_id=00000000-0000-0000-0000-000000000000
export TF_VAR_api_audience=api://agent-gateway
export TF_VAR_mcp_backend_url=https://your-mcp-backend.example.com
export TF_VAR_mcp_backend_resource=api://your-mcp-backend
export TF_VAR_agent_rate_calls=60
export TF_VAR_agent_rate_period=60
